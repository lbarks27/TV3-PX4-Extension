{
  "schema": "tv3_flight_profile_v2",
  "name": "lander_boost_upright",
  "description": "Boost-only upright ascent: guidance publishes up-setpoint, attitude tracks with BetterController, mixer runs torque-only LM.",
  "vehicle": "tv3_lander_v1",
  "scenario": {
    "type": "boost_upright",
    "simulator": "sih",
    "intent": "Isolate boost-phase attitude stability with the simplified module stack.",
    "simulated_only": true
  },
  "control": {
    "phases": [
      {
        "name": "standby",
        "on_mode": "MODE_ARMED_STANDBY",
        "modules": {
          "guidance": "off",
          "attitude": "off",
          "mixer": "off",
          "load_cell": "monitor"
        }
      },
      {
        "name": "ready",
        "on_mode": "MODE_READY",
        "modules": {
          "guidance": "off",
          "attitude": "off",
          "mixer": "off",
          "load_cell": "monitor"
        }
      },
      {
        "name": "ignition",
        "on_mode": "MODE_IGNITION_PENDING",
        "modules": {
          "guidance": "up",
          "attitude": "on",
          "mixer": "torque_only",
          "load_cell": "monitor"
        }
      },
      {
        "name": "boost_up",
        "on_mode": "MODE_BOOST",
        "modules": {
          "guidance": "up",
          "attitude": "on",
          "mixer": "torque_only",
          "load_cell": "monitor"
        }
      },
      {
        "name": "coast",
        "on_mode": "MODE_COAST",
        "modules": {
          "guidance": "off",
          "attitude": "off",
          "mixer": "off",
          "load_cell": "monitor"
        }
      }
    ]
  },
  "mission_profile": {
    "first_free_flight_gate": "single_engine_ascent",
    "required_sim_gates": [
      "sih_force_response",
      "boost_upright"
    ]
  },
  "commands": [
    {
      "at_s": 0.0,
      "action": "arm_and_ready"
    },
    {
      "at_s": 1.0,
      "action": "launch"
    }
  ],
  "review": {
    "min_boost_s": 3.0,
    "max_angular_rate_deg_s": 360.0,
    "required_topics": [
      "tv3_sm_modes",
      "tv3_gd_att_sp",
      "tv3_gd_thr_sp",
      "tv3_mix_eng_cmd",
      "tv3_lc_eng_st",
      "vehicle_attitude",
      "vehicle_angular_velocity",
      "vehicle_torque_setpoint",
      "tv3_mix_alloc_st"
    ],
    "success_criteria": [
      "guidance publishes up attitude setpoint during boost",
      "attitude produces bounded torque setpoints",
      "mixer publishes tv3_mix_eng_cmd during boost"
    ]
  }
}
