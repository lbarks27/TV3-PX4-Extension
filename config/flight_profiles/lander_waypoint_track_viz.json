{
  "schema": "tv3_flight_profile_v1",
  "name": "lander_waypoint_track_viz",
  "description": "Waypoint tracking profile tuned for visible guidance and engine command review in Hawkeye for the three-engine lander. Uses larger lateral excursions and turns to exercise differential thrust vectoring.",
  "vehicle": "tv3_lander_v1",
  "scenario": {
    "type": "waypoint_track",
    "simulator": "sih",
    "intent": "Demonstrate guidance commanding lateral/turning trajectories that produce visible vehicle motion and per-engine command changes, plus altitude changes.",
    "simulated_only": true
  },
  "guidance": {
    "enable": 1,
    "ascent_mode": "launch_ascent",
    "apogee_mode": "track",
    "landing_mode": "approach",
    "takeoff_alt_m": 8.0,
    "apex_alt_m": 25.0,
    "pos_p": 0.12,
    "vel_max_m_s": 8.0,
    "vel_up_m_s": 5.0,
    "vel_dn_m_s": 3.5,
    "yaw_deg": 0.0,
    "hold_alt_m": 8.0,
    "acceptance_m": 4.0,
    "min_twr": 1.1,
    "landing_twr": 1.2,
    "min_remaining_impulse_ns": 0.0,
    "wp1_n_m": 25.0,
    "wp1_e_m": 12.0,
    "wp1_d_m": -12.0,
    "wp2_n_m": 10.0,
    "wp2_e_m": -18.0,
    "wp2_d_m": -18.0,
    "wp1_mode": "fly_through",
    "wp2_mode": "position_hold",
    "wp2_hold_s": 5.0,
    "wp3_mode": "fly_through",
    "wp3_n_m": -15.0,
    "wp3_e_m": 8.0,
    "wp3_d_m": -10.0,
    "land_n_m": 0.0,
    "land_e_m": 0.0,
    "land_d_m": 0.0,
    "sim_groundtruth_fallback": 1
  },
  "mission_profile": {
    "first_free_flight_gate": "single_engine_ascent",
    "required_sim_gates": [
      "sih_force_response",
      "waypoint_track",
      "engine_vectoring_review"
    ]
  },
  "commands": [
    {
      "at_s": 0.0,
      "action": "arm_and_ready"
    },
    {
      "at_s": 1.0,
      "action": "launch"
    }
  ],
  "review": {
    "required_topics": [
      "tv3_guidance_status",
      "trajectory_setpoint",
      "vehicle_local_position",
      "vehicle_local_position_groundtruth",
      "tv3_engine_state",
      "control_allocator_status",
      "actuator_motors"
    ],
    "success_criteria": [
      "guidance produces non-zero lateral and turning setpoints",
      "engine splay/gimbal commands vary visibly across engines during turns",
      "vehicle follows waypoints with reasonable error before descent"
    ]
  }
}
