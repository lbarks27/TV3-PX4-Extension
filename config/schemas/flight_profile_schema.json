{
  "schema": "tv3_flight_profile_schema_v2",
  "description": "Flight profile contract for TV3. Vehicle geometry and hardware live in config/vehicles; profiles describe scenario targets and runtime control phase mapping.",
  "required_sections": [
    "schema",
    "name",
    "vehicle",
    "scenario",
    "control",
    "mission_profile"
  ],
  "generator_behavior": {
    "consumed_now": {
      "control": "maps lifecycle phases to per-module modes; emits RK_CTRL_* params",
      "mission_profile": "traceability and gate metadata"
    },
    "copied_for_traceability": [
      "generated runtime profile under etc/flight_profiles",
      "generated microSD profile under fs/microsd/tv3/flight_profiles"
    ],
    "not_consumed_yet": [
      "commands",
      "environment",
      "faults",
      "success_criteria",
      "review"
    ]
  },
  "control": {
    "description": "Maps tv3_sm_status lifecycle modes to per-module operating modes. Consumed at runtime via RK_CTRL_* params.",
    "phase_fields": {
      "name": "human-readable phase label",
      "on_mode": "tv3_sm_status mode constant: MODE_ARMED_STANDBY, MODE_READY, MODE_IGNITION_PENDING, MODE_BOOST, MODE_COAST, MODE_ABORT",
      "modules": {
        "guidance": "off | up | waypoint_fly_through",
        "attitude": "off | on",
        "mixer": "off | torque_only | torque_and_thrust",
        "load_cell": "off | monitor"
      }
    },
    "example": {
      "phases": [
        {
          "name": "standby",
          "on_mode": "MODE_ARMED_STANDBY",
          "modules": {
            "guidance": "off",
            "attitude": "off",
            "mixer": "off",
            "load_cell": "monitor"
          }
        },
        {
          "name": "boost_up",
          "on_mode": "MODE_BOOST",
          "modules": {
            "guidance": "up",
            "attitude": "on",
            "mixer": "torque_only",
            "load_cell": "monitor"
          }
        }
      ]
    }
  },
  "scenario": {
    "required": [
      "type",
      "simulator",
      "intent"
    ]
  },
  "mission_profile": {
    "required": [
      "required_sim_gates"
    ]
  },
  "commands": {
    "note": "Optional timed launch/abort/reset timeline for host scripts."
  }
}
