#!/bin/sh
#
# Shared defaults for TV3 SITL profiles.
#

set VEHICLE_TYPE tv3

param set-default MAV_TYPE 9
param set-default COM_RC_IN_MODE 4
param set-default NAV_DLL_ACT 0
param set-default COM_DISARM_PRFLT -1
param set-default COM_DISARM_LAND -1
param set-default FD_FAIL_R 0
param set-default FD_FAIL_P 0
param set-default RK_CMD_SRC 1
param set-default RK_LC_SRC 0
param set-default RK_LC_ALPHA 0.25
param set-default RK_LC_TO_MS 200
