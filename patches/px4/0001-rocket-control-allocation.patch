+		snprintf(buffer, sizeof(buffer), "CA_RK_G%u_PAZ", i);
+		_param_handles[i].pitch_axis_z = param_find(buffer);
+
+		snprintf(buffer, sizeof(buffer), "CA_RK_G%u_YAX", i);
+		_param_handles[i].yaw_axis_x = param_find(buffer);
+		snprintf(buffer, sizeof(buffer), "CA_RK_G%u_YAY", i);
