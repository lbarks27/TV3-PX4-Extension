+		snprintf(buffer, sizeof(buffer), "CA_RK_G%u_PMAX", i);
+		_param_handles[i].pitch_max = param_find(buffer);
+		snprintf(buffer, sizeof(buffer), "CA_RK_G%u_YMAX", i);
