+#pragma once
+
+#include <array>
+#include <cstddef>
+
+struct RocketMassCurvePoint {
+	float time_s;
+	float motor_mass_kg;
+};
+
+// Derived from the existing Apogee F10 thrust curve by integrating cumulative impulse
+// and consuming 41 g of propellant from an 84 g loaded motor.
+inline constexpr float kApogeeF10LoadedMassKg = 0.084f;
+inline constexpr float kApogeeF10SpentMassKg = 0.043f;
+
+inline constexpr std::array<RocketMassCurvePoint, 28> kApogeeF10MassCurve{{
+	RocketMassCurvePoint{0.000000f, 0.084000f},
