+		snprintf(buffer, sizeof(buffer), "CA_RK_G%u_YTR", i);
+		_param_handles[i].yaw_trim = param_find(buffer);
+	}
+
+	_count_handle = param_find("CA_RK_GRP_CNT");
+	_reference_thrust_handle = param_find("CA_RK_REF_THR");
+	_minimum_thrust_handle = param_find("CA_RK_MIN_THR");
+	_fallback_thrust_handle = param_find("CA_RK_FAL_THR");
+
+	updateParams();
+}
+
+void ActuatorEffectivenessRocket::updateParams()
+{
+	ModuleParams::updateParams();
+
+	int32_t count = 0;
+
+	if (param_get(_count_handle, &count) != 0) {
+		PX4_ERR("param_get failed");
+		return;
+	}
+
+	if (count < 0) {
+		count = 0;
+	}
+
+	if (count > MAX_GROUPS) {
+		count = MAX_GROUPS;
+	}
+
+	_count = count;
+
+	param_get(_reference_thrust_handle, &_reference_thrust);
+	param_get(_minimum_thrust_handle, &_minimum_thrust);
+	param_get(_fallback_thrust_handle, &_fallback_thrust);
+
+	for (int i = 0; i < _count; ++i) {
+		GroupParams &group = _groups[i];
+
+		param_get(_param_handles[i].position_x, &group.position(0));
+		param_get(_param_handles[i].position_y, &group.position(1));
+		param_get(_param_handles[i].position_z, &group.position(2));
+
+		param_get(_param_handles[i].thrust_axis_x, &group.thrust_axis(0));
+		param_get(_param_handles[i].thrust_axis_y, &group.thrust_axis(1));
+		param_get(_param_handles[i].thrust_axis_z, &group.thrust_axis(2));
+
+		param_get(_param_handles[i].pitch_axis_x, &group.pitch_axis(0));
+		param_get(_param_handles[i].pitch_axis_y, &group.pitch_axis(1));
+		param_get(_param_handles[i].pitch_axis_z, &group.pitch_axis(2));
+
+		param_get(_param_handles[i].yaw_axis_x, &group.yaw_axis(0));
+		param_get(_param_handles[i].yaw_axis_y, &group.yaw_axis(1));
+		param_get(_param_handles[i].yaw_axis_z, &group.yaw_axis(2));
+
+		float pitch_max_deg = 0.f;
+		float yaw_max_deg = 0.f;
+		param_get(_param_handles[i].pitch_max, &pitch_max_deg);
+		param_get(_param_handles[i].yaw_max, &yaw_max_deg);
+		group.pitch_max_rad = math::radians(pitch_max_deg);
+		group.yaw_max_rad = math::radians(yaw_max_deg);
+
+		param_get(_param_handles[i].thrust_fraction, &group.thrust_fraction);
+		param_get(_param_handles[i].pitch_trim, &group.pitch_trim);
+		param_get(_param_handles[i].yaw_trim, &group.yaw_trim);
+	}
+}
+
+Vector3f ActuatorEffectivenessRocket::normalizeOrDefault(const Vector3f &axis, const Vector3f &fallback)
+{
+	const float norm = axis.norm();
+
+	if (norm > FLT_EPSILON) {
+		return axis / norm;
+	}
+
+	return fallback;
+}
+
+Vector3f ActuatorEffectivenessRocket::computeTorque(const Vector3f &lever_arm, const Vector3f &thrust_axis,
+		const Vector3f &gimbal_axis, float thrust_scale, float max_angle_rad)
+{
+	// Small-angle TVC linearization: delta thrust direction ~= gimbal_axis x thrust_axis.
+	return thrust_scale * max_angle_rad * lever_arm.cross(gimbal_axis.cross(thrust_axis));
+}
+
+bool ActuatorEffectivenessRocket::getEffectivenessMatrix(Configuration &configuration,
+		EffectivenessUpdateReason external_update)
+{
+	if (external_update == EffectivenessUpdateReason::NO_EXTERNAL_UPDATE) {
+		return false;
+	}
+
+	updateParams();
+
+	if (_count <= 0) {
+		PX4_ERR("No rocket TVC groups configured");
+		return false;
+	}
+
+	configuration.selected_matrix = 0;
+
+	for (int i = 0; i < _count; ++i) {
+		const GroupParams &group = _groups[i];
+		const Vector3f thrust_axis = normalizeOrDefault(group.thrust_axis, Vector3f{1.f, 0.f, 0.f});
+		const Vector3f pitch_axis = normalizeOrDefault(group.pitch_axis, Vector3f{0.f, -1.f, 0.f});
+		const Vector3f yaw_axis = normalizeOrDefault(group.yaw_axis, Vector3f{0.f, 0.f, -1.f});
+		const float thrust_scale = _reference_thrust * math::constrain(group.thrust_fraction, 0.f, 1.f);
+
+		int pitch_idx = configuration.addActuator(ActuatorType::SERVOS,
+				computeTorque(group.position, thrust_axis, pitch_axis, thrust_scale, group.pitch_max_rad), Vector3f{});
+
+		if (pitch_idx >= 0) {
+			configuration.trim[configuration.selected_matrix](pitch_idx) = group.pitch_trim;
+		}
+
+		int yaw_idx = configuration.addActuator(ActuatorType::SERVOS,
+				computeTorque(group.position, thrust_axis, yaw_axis, thrust_scale, group.yaw_max_rad), Vector3f{});
+
+		if (yaw_idx >= 0) {
+			configuration.trim[configuration.selected_matrix](yaw_idx) = group.yaw_trim;
+		}
+	}
+
+	return true;
+}

