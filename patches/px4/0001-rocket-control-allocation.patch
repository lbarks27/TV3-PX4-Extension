+++ b/src/modules/control_allocator/VehicleActuatorEffectiveness/ActuatorEffectivenessRocket.hpp
@@ -0,0 +1,92 @@
+#pragma once
+
+#include "control_allocation/actuator_effectiveness/ActuatorEffectiveness.hpp"
+
+#include <px4_platform_common/module_params.h>
+
+class ActuatorEffectivenessRocket : public ModuleParams, public ActuatorEffectiveness
+{
+public:
+	static constexpr int MAX_GROUPS = 4;
+
+	explicit ActuatorEffectivenessRocket(ModuleParams *parent);
+	~ActuatorEffectivenessRocket() override = default;
+
+	bool getEffectivenessMatrix(Configuration &configuration, EffectivenessUpdateReason external_update) override;
+
+	const char *name() const override { return "Rocket"; }
+
+private:
+	void updateParams() override;
+
+	struct GroupParams {
+		matrix::Vector3f position{};
+		matrix::Vector3f thrust_axis{};
+		matrix::Vector3f pitch_axis{};
+		matrix::Vector3f yaw_axis{};
+		float pitch_max_rad{0.f};
+		float yaw_max_rad{0.f};
+		float thrust_fraction{0.f};
+		float pitch_trim{0.f};
+		float yaw_trim{0.f};
+	};
+
+	struct ParamHandles {
+		param_t position_x;
+		param_t position_y;
+		param_t position_z;
+		param_t thrust_axis_x;
+		param_t thrust_axis_y;
+		param_t thrust_axis_z;
+		param_t pitch_axis_x;
+		param_t pitch_axis_y;
+		param_t pitch_axis_z;
+		param_t yaw_axis_x;
+		param_t yaw_axis_y;
+		param_t yaw_axis_z;
+		param_t pitch_max;
+		param_t yaw_max;
+		param_t thrust_fraction;
+		param_t pitch_trim;
+		param_t yaw_trim;
+	};
+
+	static matrix::Vector3f normalizeOrDefault(const matrix::Vector3f &axis, const matrix::Vector3f &fallback);
+	static matrix::Vector3f computeTorque(const matrix::Vector3f &lever_arm, const matrix::Vector3f &thrust_axis,
+					      const matrix::Vector3f &gimbal_axis, float thrust_scale, float max_angle_rad);
+
+	ParamHandles _param_handles[MAX_GROUPS]{};
+	param_t _count_handle{};
+	param_t _reference_thrust_handle{};
+	param_t _minimum_thrust_handle{};
+	param_t _fallback_thrust_handle{};
+
+	GroupParams _groups[MAX_GROUPS]{};
+	int _count{0};
+	float _reference_thrust{0.f};
+	float _minimum_thrust{0.f};
+	float _fallback_thrust{0.f};
+};

